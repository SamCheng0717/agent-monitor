# =============================================================================
# agent-monitor 环境变量配置模板
# =============================================================================
# 使用方式：复制此文件为 .env，填入真实值
#   cp .env.example .env
# =============================================================================

# ── DeepSeek（质量评分 LLM）─────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 评分模型名称（可选，默认 deepseek-chat）
# MODEL=deepseek-chat

# ── 本地 LLM（留资检测，Qwen3-14B）───────────────────────────────────────────
LOCAL_API_KEY=placeholder
LOCAL_BASE_URL=http://localhost:11434/v1
# 留资检测模型名称（可选，默认 Qwen/Qwen3-14B-AWQ）
# LOCAL_MODEL=Qwen/Qwen3-14B-AWQ

# ── 主管 LLM（提示词演进，Qwen3.5-27B）───────────────────────────────────────
ADVISOR_API_KEY=placeholder
ADVISOR_BASE_URL=http://localhost:11434/v1
# 主管模型名称（可选，默认 Qwen/Qwen3.5-27B-FP8）
# ADVISOR_MODEL=Qwen/Qwen3.5-27B-FP8

# ── Dify App API ────────────────────────────────────────────────────────────
DIFY_BASE_URL=http://localhost:80
DIFY_API_KEY=app-your-dify-api-key
DIFY_APP_ID=your-dify-app-id

# ── 数据库（OceanBase / MySQL，用于拉取群成员 ID）───────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=your-db-password
DB_NAME=your-database-name

# ── 钉钉机器人通知（可选）────────────────────────────────────────────────────
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your-token
DINGTALK_SECRET=your-hmac-sha256-secret
